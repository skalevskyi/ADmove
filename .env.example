# Resend — required for POST /api/lead (set in Vercel for production)
RESEND_API_KEY=

# Inbox that receives lead notifications — required in production (no placeholder fallback in code)
LEAD_TO_EMAIL=

# Sender shown by Resend. Optional for local/tests (defaults to Resend onboarding address).
# Production: set to an address on a domain verified in Resend.
# RESEND_FROM_EMAIL=
